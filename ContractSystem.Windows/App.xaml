<Application x:Class="ContractSystem.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ContractSystem.Windows"
             xmlns:vm="clr-namespace:ContractSystem.Windows.ViewModels"
             xmlns:viewsInicio="clr-namespace:ContractSystem.Windows.Views.Inicio"
             xmlns:viewsGestionUsuarios="clr-namespace:ContractSystem.Windows.Views.GestionUsuarios"
             xmlns:viewsConfiguracion="clr-namespace:ContractSystem.Windows.Views.Configuracion"
             xmlns:viewsContratos="clr-namespace:ContractSystem.Windows.Views.Contratos"
             xmlns:converters="clr-namespace:ContractSystem.Windows.Converters"
             Startup="Application_Startup">
    <Application.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:BoolToEstadoUsuarioConverter x:Key="BoolToEstadoUsuario"/>
        <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSource"/>
        <!-- Paleta de colores estilo Microsoft Store / App moderna -->
        <SolidColorBrush x:Key="BrushBackground" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="BrushError" Color="#C42B1C"/>
        <SolidColorBrush x:Key="BrushSidebar" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="BrushAccent" Color="#0078D4"/>
        <SolidColorBrush x:Key="BrushTextInactive" Color="#5C5C5C"/>
        <SolidColorBrush x:Key="BrushTextActive" Color="#0078D4"/>
        <SolidColorBrush x:Key="BrushBorder" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="BrushHover" Color="#E8F4FC"/>
        <SolidColorBrush x:Key="BrushCloseHover" Color="#E81123"/>
        
        <!-- Estilo general listados: selección con foco = blanco sobre accent; sin foco = texto oscuro sobre fondo claro (buen contraste al maximizar/cambiar foco) -->
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <!-- Seleccionada y el DataGrid tiene foco: texto blanco, fondo accent -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                        <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                </MultiDataTrigger>
                <!-- Seleccionada pero sin foco (p. ej. al maximizar): texto oscuro, fondo claro para buen contraste -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                        <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextInactive}"/>
                    <Setter Property="Background" Value="{StaticResource BrushHover}"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True"/>
                        <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="White"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True"/>
                        <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextInactive}"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListViewItem">
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextInactive}"/>
                    <Setter Property="Background" Value="{StaticResource BrushHover}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListBoxItem">
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextInactive}"/>
                    <Setter Property="Background" Value="{StaticResource BrushHover}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- Estilo denso para botones de la barra de título (minimize, maximize, full screen) -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Estilo denso para botón cerrar (hover rojo) -->
        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushCloseHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Validation.ErrorTemplate: mensaje en rojo debajo del campo con error (INotifyDataErrorInfo) -->
        <ControlTemplate x:Key="ValidationErrorTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="placeholder"/>
                <TextBlock Text="{Binding [0].ErrorContent}" Foreground="{StaticResource BrushError}"
                           FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </ControlTemplate>

        <!-- TextBox con validación: usar Validation.ErrorTemplate para mostrar errores debajo del campo -->
        <Style TargetType="TextBox" x:Key="ValidatableTextBoxStyle">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}"/>
        </Style>

        <!-- DataTemplates: ViewModel -> View (navegación MVVM) -->
        <DataTemplate DataType="{x:Type vm:InicioViewModel}">
            <viewsInicio:InicioView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GestionUsuariosViewModel}">
            <viewsGestionUsuarios:GestionUsuariosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfiguracionViewModel}">
            <viewsConfiguracion:ConfiguracionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BusinessInfoViewModel}">
            <viewsConfiguracion:BusinessInfoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NomencladoresViewModel}">
            <viewsConfiguracion:NomencladoresView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UnidadMedidaViewModel}">
            <viewsConfiguracion:UnidadMedidaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TerceroViewModel}">
            <viewsConfiguracion:TerceroView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductoServicioViewModel}">
            <viewsConfiguracion:ProductoServicioView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlantillaDocumentoViewModel}">
            <viewsConfiguracion:PlantillaDocumentoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NumeracionConfigViewModel}">
            <viewsConfiguracion:NumeracionConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContratosViewModel}">
            <viewsContratos:ContratosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ArbolContratosViewModel}">
            <viewsContratos:ArbolContratosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExpedienteTerceroViewModel}">
            <viewsContratos:ExpedienteTerceroView/>
        </DataTemplate>

        <!-- Estilo para elementos del menú lateral -->
        <Style x:Key="NavItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                Padding="8,12" CornerRadius="4"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
