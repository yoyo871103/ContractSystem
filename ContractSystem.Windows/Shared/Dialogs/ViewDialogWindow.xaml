<Window x:Class="ContractSystem.Windows.Shared.Dialogs.ViewDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinWidth="500" MinHeight="400"
        Width="900" Height="600"
        Background="{StaticResource BrushBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Contenedor de la vista -->
        <Border Grid.Row="0" Margin="16" Padding="16" Background="White"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="4">
            <ContentControl x:Name="DialogContentHost" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Border>
        <!-- Barra de botones -->
        <Border Grid.Row="1" Background="{StaticResource BrushSidebar}" Padding="16,12"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCerrar" Content="Cerrar" Width="80" Height="32"
                        Background="{StaticResource BrushAccent}" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnCerrar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
