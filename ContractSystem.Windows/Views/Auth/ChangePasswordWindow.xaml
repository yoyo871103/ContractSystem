<Window x:Class="ContractSystem.Windows.Views.Auth.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="WinRoot" Title="Cambiar contraseña"
        Height="360" Width="400"
        MinHeight="320" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Título (fijo) -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtHeader" Grid.Column="0" Text="Debe cambiar su contraseña antes de continuar"
                               FontSize="12" Foreground="{StaticResource BrushTextInactive}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Cerrar (cancelar)" Click="BtnCancelar_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource BrushTextInactive}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
            <!-- Cuerpo (con scroll) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,20">
                <StackPanel>
                <TextBlock Text="Contraseña actual" FontSize="12" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                <Border Margin="0,0,0,16" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White">
                    <Grid Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0">
                            <PasswordBox x:Name="TxtActual" FontSize="14" Padding="10,8,4,8"
                                         BorderThickness="0" Background="Transparent"/>
                            <TextBox x:Name="TxtActualVisible" FontSize="14" Padding="10,8,4,8"
                                     BorderThickness="0" Background="Transparent" Visibility="Collapsed"
                                     TextChanged="TxtActualVisible_TextChanged"/>
                        </Grid>
                        <Button x:Name="BtnVerActual" Grid.Column="1" Width="36" Height="36" Padding="0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="Mostrar contraseña" Click="BtnVerActual_Click">
                            <TextBlock x:Name="IconoOjoActual" Text="&#xE890;" FontFamily="Segoe Fluent Icons"
                                       FontSize="14" Foreground="{StaticResource BrushTextInactive}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Text="Nueva contraseña" FontSize="12" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                <Border Margin="0,0,0,16" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White">
                    <Grid Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0">
                            <PasswordBox x:Name="TxtNueva" FontSize="14" Padding="10,8,4,8"
                                         BorderThickness="0" Background="Transparent"/>
                            <TextBox x:Name="TxtNuevaVisible" FontSize="14" Padding="10,8,4,8"
                                     BorderThickness="0" Background="Transparent" Visibility="Collapsed"
                                     TextChanged="TxtNuevaVisible_TextChanged"/>
                        </Grid>
                        <Button x:Name="BtnVerNueva" Grid.Column="1" Width="36" Height="36" Padding="0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="Mostrar contraseña" Click="BtnVerNueva_Click">
                            <TextBlock x:Name="IconoOjoNueva" Text="&#xE890;" FontFamily="Segoe Fluent Icons"
                                       FontSize="14" Foreground="{StaticResource BrushTextInactive}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Text="Confirmar nueva contraseña" FontSize="12" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                <Border Margin="0,0,0,24" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White">
                    <Grid Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0">
                            <PasswordBox x:Name="TxtConfirmar" FontSize="14" Padding="10,8,4,8"
                                         BorderThickness="0" Background="Transparent"/>
                            <TextBox x:Name="TxtConfirmarVisible" FontSize="14" Padding="10,8,4,8"
                                     BorderThickness="0" Background="Transparent" Visibility="Collapsed"
                                     TextChanged="TxtConfirmarVisible_TextChanged"/>
                        </Grid>
                        <Button x:Name="BtnVerConfirmar" Grid.Column="1" Width="36" Height="36" Padding="0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="Mostrar contraseña" Click="BtnVerConfirmar_Click">
                            <TextBlock x:Name="IconoOjoConfirmar" Text="&#xE890;" FontFamily="Segoe Fluent Icons"
                                       FontSize="14" Foreground="{StaticResource BrushTextInactive}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>
                </StackPanel>
            </ScrollViewer>
            <!-- Pie fijo: botones de acción -->
            <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancelar" Content="Cancelar" IsCancel="True" Margin="0,0,8,0"
                            Padding="16,8" Height="32" Click="BtnCancelar_Click"/>
                    <Button x:Name="BtnAceptar" Content="Cambiar contraseña" IsDefault="True"
                            Padding="16,8" Height="32" Background="{StaticResource BrushAccent}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnAceptar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
