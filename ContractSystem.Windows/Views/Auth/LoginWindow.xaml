<Window x:Class="ContractSystem.Windows.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Iniciar sesión - Sistema de Contratos"
        Height="500" Width="420"
        MinHeight="480" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra superior: engrane + texto de conexión -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Icono engrane (configuración de conexión) -->
                    <Button x:Name="BtnConfigConexion" Grid.Column="0"
                            Background="Transparent" BorderThickness="0"
                            Width="36" Height="36" Padding="0" Cursor="Hand"
                            ToolTip="Configurar conexión"
                            Click="BtnConfigConexion_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent"
                                        CornerRadius="4" Padding="4">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="18" Foreground="{StaticResource BrushTextInactive}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource BrushHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Texto de conexión actual -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="Conexión actual" FontSize="10" Foreground="{StaticResource BrushTextInactive}"/>
                        <TextBlock x:Name="TxtConexionActual" Text="(no configurada)"
                                   FontSize="12" Foreground="{StaticResource BrushTextInactive}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <!-- Cerrar (opcional, para consistencia) -->
                    <Button Grid.Column="2" Width="28" Height="28" Padding="0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="BtnCerrar_Click" ToolTip="Cerrar">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Contenido: usuario, contraseña, botón (sin scroll) -->
            <StackPanel Grid.Row="1" Margin="32,24" VerticalAlignment="Center">
                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                           FontSize="36" Foreground="{StaticResource BrushAccent}"
                           HorizontalAlignment="Center" Opacity="0.9"/>
                <TextBlock Text="Sistema de Contratos" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextInactive}"
                           HorizontalAlignment="Center" Margin="0,10,0,18"/>

                <TextBlock Text="Usuario" FontSize="12" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtUsuario" FontSize="14" Padding="10,8" Height="36"
                         BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                         Margin="0,0,0,12" KeyDown="TxtUsuario_KeyDown"/>

                <TextBlock Text="Contraseña" FontSize="12" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                <Border Margin="0,0,0,14" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White">
                    <Grid Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0">
                            <PasswordBox x:Name="TxtPassword" FontSize="14" Padding="10,8,4,8"
                                         BorderThickness="0" Background="Transparent" KeyDown="TxtPassword_KeyDown"/>
                            <TextBox x:Name="TxtPasswordVisible" FontSize="14" Padding="10,8,4,8"
                                     BorderThickness="0" Background="Transparent" Visibility="Collapsed"
                                     TextChanged="TxtPasswordVisible_TextChanged" KeyDown="TxtPasswordVisible_KeyDown"/>
                        </Grid>
                        <Button x:Name="BtnVerPassword" Grid.Column="1" Width="36" Height="36"
                                Padding="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="Mostrar contraseña" Click="BtnVerPassword_Click">
                            <TextBlock x:Name="IconoOjo" Text="&#xE890;" FontFamily="Segoe Fluent Icons"
                                       FontSize="14" Foreground="{StaticResource BrushTextInactive}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Sección admin SQL colapsable -->
                <StackPanel x:Name="PnlAdminSqlContainer" Visibility="Collapsed">
                    <Button x:Name="BtnToggleAdminSql" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" HorizontalAlignment="Left" Padding="0" Margin="0,0,0,6"
                            Click="BtnToggleAdminSql_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtToggleArrow" Text="▸" FontSize="11"
                                       Foreground="{StaticResource BrushTextInactive}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Acceso administrador SQL" FontSize="11"
                                       Foreground="{StaticResource BrushTextInactive}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <StackPanel x:Name="PnlAdminSqlContent" Visibility="Collapsed">
                        <CheckBox x:Name="ChkAdminSql" Content="Entrar como administrador SQL (solo gestión de usuarios)"
                                  FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,6"/>
                        <Border x:Name="PanelAdminSql" Margin="0,0,0,12"
                                Padding="8" Background="{StaticResource BrushHover}" CornerRadius="4">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource BrushTextInactive}">
                                <Run Text="Use credenciales de administrador de SQL Server (p. ej. sa). Solo tendrá acceso a gestión de usuarios."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="BtnIniciarSesion" Content="Iniciar sesión"
                        FontSize="14" Padding="24,12" Height="44"
                        Background="{StaticResource BrushAccent}" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnIniciarSesion_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
