<UserControl x:Class="ContractSystem.Windows.Views.Contratos.ContratosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                       Foreground="{StaticResource BrushAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Contratos" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextInactive}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Barra de acciones -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Actualizar" Padding="12,6" Command="{Binding CargarCommand}"/>
            <Button Content="Nuevo contrato" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding NuevoCommand}"
                    Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"/>
            <Button Content="Editar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding EditarCommand}"
                    ToolTip="Editar el contrato seleccionado"/>
<Button Content="Nuevo suplemento" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding NuevoSuplementoCommand}"
                    ToolTip="Crear suplemento del contrato seleccionado"/>
            <Button Content="Adjuntos" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding VerAdjuntosCommand}"
                    ToolTip="Gestionar documentos adjuntos del contrato seleccionado"/>
            <Button Content="Estado" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding CambiarEstadoCommand}"
                    ToolTip="Cambiar el estado del contrato seleccionado"/>
            <Button Content="Historial" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding VerHistorialCommand}"
                    ToolTip="Ver historial de cambios del contrato seleccionado"/>
            <Button Content="Eliminar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding EliminarCommand}"/>
        </StackPanel>

        <!-- Panel de filtros -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="Tipo:" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource BrushTextInactive}" Margin="0,0,6,0"/>
                <ComboBox x:Name="CmbFiltroTipo" Width="130" Padding="6,4" FontSize="12"
                          SelectionChanged="CmbFiltroTipo_SelectionChanged">
                    <ComboBoxItem Content="Todos" IsSelected="True" Tag=""/>
                    <ComboBoxItem Content="Marco" Tag="0"/>
                    <ComboBoxItem Content="Específico" Tag="1"/>
                    <ComboBoxItem Content="Independiente" Tag="2"/>
                    <ComboBoxItem Content="Suplemento" Tag="3"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="Estado:" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource BrushTextInactive}" Margin="0,0,6,0"/>
                <ComboBox x:Name="CmbFiltroEstado" Width="120" Padding="6,4" FontSize="12"
                          SelectionChanged="CmbFiltroEstado_SelectionChanged">
                    <ComboBoxItem Content="Todos" IsSelected="True" Tag=""/>
                    <ComboBoxItem Content="Borrador" Tag="0"/>
                    <ComboBoxItem Content="Vigente" Tag="1"/>
                    <ComboBoxItem Content="Vencido" Tag="2"/>
                    <ComboBoxItem Content="Rescindido" Tag="3"/>
                    <ComboBoxItem Content="Ejecutado" Tag="4"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="Rol:" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource BrushTextInactive}" Margin="0,0,6,0"/>
                <ComboBox x:Name="CmbFiltroRol" Width="110" Padding="6,4" FontSize="12"
                          SelectionChanged="CmbFiltroRol_SelectionChanged">
                    <ComboBoxItem Content="Todos" IsSelected="True" Tag=""/>
                    <ComboBoxItem Content="Proveedor" Tag="0"/>
                    <ComboBoxItem Content="Cliente" Tag="1"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="Tercero:" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource BrushTextInactive}" Margin="0,0,6,0"/>
                <ComboBox x:Name="CmbFiltroTercero" Width="160" Padding="6,4" FontSize="12"
                          ItemsSource="{Binding TercerosFiltro}"
                          DisplayMemberPath="Nombre"
                          SelectionChanged="CmbFiltroTercero_SelectionChanged">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}"/>
                    </ComboBox.Resources>
                </ComboBox>
                <Button Content="X" Width="22" Height="22" Padding="0" Margin="2,0,0,0"
                        FontSize="10" Background="Transparent" BorderThickness="0" Cursor="Hand"
                        ToolTip="Limpiar filtro tercero"
                        Click="BtnLimpiarTercero_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="Buscar:" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource BrushTextInactive}" Margin="0,0,6,0"/>
                <TextBox Width="180" Padding="6,4" FontSize="12"
                         Text="{Binding FiltroBusqueda, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         ToolTip="Buscar por número u objeto"/>
            </StackPanel>

            <CheckBox Content="Incluir eliminados" IsChecked="{Binding IncludeDeleted, Mode=TwoWay}"
                      VerticalAlignment="Center" Margin="0,0,0,4"/>
        </WrapPanel>

        <!-- DataGrid de contratos -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Contratos}"
                  SelectedItem="{Binding Seleccionado, Mode=TwoWay}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                  MinHeight="200"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Editar" Command="{Binding EditarCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Cambiar estado" Command="{Binding CambiarEstadoCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Historial" Command="{Binding VerHistorialCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Nuevo suplemento" Command="{Binding NuevoSuplementoCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Adjuntos" Command="{Binding VerAdjuntosCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Mapa de modificaciones" Click="CtxVerMapa_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8C4;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Eliminar" Command="{Binding EliminarCommand}" Foreground="#DC3545">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#DC3545"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="140"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoDocumento}" Width="100"/>
                <DataGridTextColumn Header="Objeto" Binding="{Binding Objeto}" Width="*"/>
                <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="80"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="90"/>
                <DataGridTextColumn Header="Tercero" Binding="{Binding Tercero.Nombre}" Width="150"/>
                <DataGridTextColumn Header="Fecha Firma" Binding="{Binding FechaFirma, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Vigencia" Binding="{Binding FechaVigencia, StringFormat=dd/MM/yyyy}" Width="100"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <!-- Contratos próximos a vencer (30 días) - fondo amarillo claro -->
                        <DataTrigger Binding="{Binding Estado}" Value="Vencido">
                            <Setter Property="Background" Value="#FFF3CD"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Estado}" Value="Rescindido">
                            <Setter Property="Foreground" Value="#999999"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </Grid>
</UserControl>
