<Window x:Class="ContractSystem.Windows.Views.Contratos.CambiarEstadoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar Estado"
        Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10">
                <TextBlock Text="Cambiar Estado del Contrato" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextActive}"/>
            </Border>

            <!-- Cuerpo -->
            <StackPanel Grid.Row="1" Margin="16">
                <TextBlock x:Name="TxtEstadoActual" FontSize="12"
                           Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,12"/>
                <TextBlock Text="Nuevo estado:" FontSize="12" Margin="0,0,0,6"/>
                <ComboBox x:Name="CmbEstado" Padding="6,4" FontSize="12"/>
            </StackPanel>

            <!-- Pie -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Padding="16,8" Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button Content="Cambiar" Padding="16,8" Margin="8,0,0,0" Cursor="Hand"
                            Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                            Click="BtnCambiar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
