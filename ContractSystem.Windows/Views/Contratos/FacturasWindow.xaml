<Window x:Class="ContractSystem.Windows.Views.Contratos.FacturasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Facturas"
        Height="500" Width="750"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtTitulo" Grid.Column="0" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextActive}"/>
                    <Button Grid.Column="1" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Cerrar" Click="BtnCerrar_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource BrushTextInactive}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Cuerpo -->
            <Grid Grid.Row="1" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Botones -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Nueva factura" Padding="12,6"
                            Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="BtnNueva_Click"/>
                    <Button Content="Editar" Padding="12,6" Margin="8,0,0,0"
                            Cursor="Hand" Click="BtnEditar_Click"/>
                    <Button Content="Eliminar" Padding="12,6" Margin="8,0,0,0"
                            Cursor="Hand" Click="BtnEliminar_Click"/>
                </StackPanel>

                <!-- DataGrid de facturas -->
                <DataGrid Grid.Row="1" x:Name="DgFacturas"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                          MouseDoubleClick="DgFacturas_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="140"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Importe Total" Binding="{Binding ImporteTotal, StringFormat=N2}" Width="120"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Totales -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <TextBlock Text="Total facturado:" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtTotalFacturado" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource BrushAccent}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Pie fijo -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <Button Content="Cerrar" Padding="16,8" Cursor="Hand" HorizontalAlignment="Right"
                        Click="BtnCerrar_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
