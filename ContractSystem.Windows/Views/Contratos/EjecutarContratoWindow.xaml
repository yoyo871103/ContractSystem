<Window x:Class="ContractSystem.Windows.Views.Contratos.EjecutarContratoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ejecutar Contrato"
        Height="400" Width="500"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10">
                <TextBlock x:Name="TxtTitulo" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextActive}"/>
            </Border>

            <!-- Cuerpo -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12"
                               Foreground="{StaticResource BrushTextInactive}">
                        El contrato será marcado como Ejecutado. Seleccione los suplementos que desea marcar también como ejecutados:
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Seleccionar todos" Padding="8,4" FontSize="11" Cursor="Hand"
                                Click="BtnSeleccionarTodos_Click"/>
                        <Button Content="Deseleccionar todos" Padding="8,4" FontSize="11" Cursor="Hand"
                                Margin="8,0,0,0" Click="BtnDeseleccionarTodos_Click"/>
                    </StackPanel>
                    <ItemsControl x:Name="ListaSuplementos"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Padding="16,8" Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button Content="Ejecutar" Padding="16,8" Margin="8,0,0,0" Cursor="Hand"
                            Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                            Click="BtnEjecutar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
