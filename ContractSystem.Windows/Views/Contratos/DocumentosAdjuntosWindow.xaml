<Window x:Class="ContractSystem.Windows.Views.Contratos.DocumentosAdjuntosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Documentos Adjuntos"
        Height="500" Width="700"
        MinHeight="400" MinWidth="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtTitulo" Grid.Column="0" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextActive}"/>
                    <Button Grid.Column="1" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Cerrar" Click="BtnCerrar_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource BrushTextInactive}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Cuerpo -->
            <Grid Grid.Row="1" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Botones -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Adjuntar archivo" Padding="12,6"
                            Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="BtnAdjuntar_Click"/>
                    <Button Content="Descargar" Padding="12,6" Margin="8,0,0,0"
                            Cursor="Hand" Click="BtnDescargar_Click"/>
                    <Button Content="Eliminar" Padding="12,6" Margin="8,0,0,0"
                            Cursor="Hand" Click="BtnEliminar_Click"/>
                </StackPanel>

                <!-- DataGrid de adjuntos -->
                <DataGrid Grid.Row="1" x:Name="DgAdjuntos"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                          MouseDoubleClick="DgAdjuntos_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding NombreArchivo}" Width="*"/>
                        <DataGridTextColumn Header="Ext." Binding="{Binding Extension}" Width="60"/>
                        <DataGridTextColumn Header="Objetivo" Binding="{Binding Objetivo}" Width="*"/>
                        <DataGridTextColumn Header="Tamaño" Binding="{Binding TamanioTexto}" Width="90"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCarga, StringFormat=dd/MM/yyyy HH:mm}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Pie fijo -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <Button Content="Cerrar" Padding="16,8" Cursor="Hand" HorizontalAlignment="Right"
                        Click="BtnCerrar_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
