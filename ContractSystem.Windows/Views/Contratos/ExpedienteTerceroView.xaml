<UserControl x:Class="ContractSystem.Windows.Views.Contratos.ExpedienteTerceroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                       Foreground="{StaticResource BrushAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Expediente por Tercero" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextInactive}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Selector de tercero -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Tercero:" VerticalAlignment="Center" FontSize="12"
                       Foreground="{StaticResource BrushTextInactive}" Margin="0,0,8,0"/>
            <ComboBox Width="300" Padding="6,4" FontSize="12"
                      ItemsSource="{Binding Terceros}"
                      SelectedItem="{Binding TerceroSeleccionado, Mode=TwoWay}"
                      DisplayMemberPath="Nombre"
                      IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="Nombre"/>
            <Button Content="Actualizar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding CargarExpedienteCommand}"/>
        </StackPanel>

        <!-- Resumen -->
        <TextBlock Grid.Row="2" Text="{Binding Resumen}" FontSize="12"
                   Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,8">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Resumen}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- TreeView del expediente -->
        <TreeView Grid.Row="3" x:Name="TvExpediente" ItemsSource="{Binding Nodos}"
                  BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                  MouseDoubleClick="TvExpediente_MouseDoubleClick">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Hijos}">
                    <StackPanel Orientation="Horizontal" Margin="2,3">
                        <TextBlock Text="{Binding Icono}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{Binding Color}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="{Binding Titulo}" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{Binding Color}"/>
                            <TextBlock Text="{Binding Subtitulo}" FontSize="11"
                                       Foreground="{StaticResource BrushTextInactive}"/>
                        </StackPanel>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
