<Window x:Class="ContractSystem.Windows.Views.Contratos.DetalleContratoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Contrato"
        Height="600" Width="800"
        MinHeight="500" MinWidth="650"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtTitulo" Grid.Column="0" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextActive}"/>
                    <Button Grid.Column="1" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Cerrar" Click="BtnCerrar_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource BrushTextInactive}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Cuerpo con scroll -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <!-- Datos generales -->
                    <TextBlock Text="Datos generales" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource BrushAccent}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Número:" FontWeight="SemiBold" Margin="0,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtNumero" FontSize="12" Margin="0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Tipo:" FontWeight="SemiBold" Margin="16,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" x:Name="TxtTipo" FontSize="12" Margin="0,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Estado:" FontWeight="SemiBold" Margin="0,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtEstado" FontSize="12" FontWeight="SemiBold" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Rol:" FontWeight="SemiBold" Margin="16,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" x:Name="TxtRol" FontSize="12" Margin="0,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tercero:" FontWeight="SemiBold" Margin="0,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtTercero" FontSize="12" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Valor total:" FontWeight="SemiBold" Margin="16,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="2" Grid.Column="3" x:Name="TxtValorTotal" FontSize="12" Margin="0,2"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Fecha firma:" FontWeight="SemiBold" Margin="0,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtFechaFirma" FontSize="12" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Vigencia:" FontWeight="SemiBold" Margin="16,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="3" Grid.Column="3" x:Name="TxtFechaVigencia" FontSize="12" Margin="0,2"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Objeto:" FontWeight="SemiBold" Margin="0,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" x:Name="TxtObjeto" FontSize="12" Margin="0,2" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Duración:" FontWeight="SemiBold" Margin="0,2,12,2" FontSize="12"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtDuracion" FontSize="12" Margin="0,2"/>
                    </Grid>

                    <!-- Anexos y líneas -->
                    <TextBlock Text="Anexos y líneas de detalle" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource BrushAccent}" Margin="0,0,0,4"/>
                    <StackPanel x:Name="PnlAnexos" Margin="0,0,0,16"/>

                    <!-- Documentos adjuntos -->
                    <TextBlock Text="Documentos adjuntos" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource BrushAccent}" Margin="0,0,0,4"/>
                    <DataGrid x:Name="DgAdjuntos" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                              MaxHeight="200" Margin="0,0,0,16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Archivo" Binding="{Binding NombreArchivo}" Width="*"/>
                            <DataGridTextColumn Header="Ext." Binding="{Binding Extension}" Width="50"/>
                            <DataGridTextColumn Header="Objetivo" Binding="{Binding Objetivo}" Width="200"/>
                            <DataGridTextColumn Header="Tamaño" Binding="{Binding TamanioTexto}" Width="80"/>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCarga, StringFormat=dd/MM/yyyy}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Anexos/Líneas" Padding="12,6" Margin="0,0,8,0" Cursor="Hand"
                            Click="BtnAbrirAnexos_Click"/>
                    <Button Content="Adjuntos" Padding="12,6" Margin="0,0,8,0" Cursor="Hand"
                            Click="BtnAbrirAdjuntos_Click"/>
                    <Button Padding="12,6" Margin="0,0,8,0" Cursor="Hand"
                            Click="BtnAbrirMapa_Click" ToolTip="Ver mapa de modificaciones">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C4;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Modificaciones" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Cerrar" Padding="16,8" Cursor="Hand"
                            Click="BtnCerrar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
