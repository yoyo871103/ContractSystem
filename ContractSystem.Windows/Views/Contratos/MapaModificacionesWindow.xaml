<Window x:Class="ContractSystem.Windows.Views.Contratos.MapaModificacionesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapa de Modificaciones"
        Height="600" Width="850"
        MinHeight="450" MinWidth="650"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtTitulo" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextActive}"/>
                        <TextBlock x:Name="TxtSubtitulo" FontSize="11"
                                   Foreground="{StaticResource BrushTextInactive}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Cerrar" Click="BtnCerrar_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource BrushTextInactive}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Cuerpo con Tabs -->
            <TabControl Grid.Row="1" Margin="8,4,8,0" BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BrushBorder}">
                <TabItem Header="  Diagrama visual  " Padding="8,4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <Canvas x:Name="CnvDiagrama" MinWidth="700" MinHeight="400"
                                Background="White" ClipToBounds="False"/>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="  Lista de relaciones  " Padding="8,4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel x:Name="PnlDiagrama" Margin="8"/>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- Pie -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                        <Border Width="12" Height="12" CornerRadius="2" Background="#0078D4" Margin="0,0,4,0"/>
                        <TextBlock Text="Padre" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,12,0"/>
                        <Border Width="12" Height="12" CornerRadius="2" Background="#28A745" Margin="0,0,4,0"/>
                        <TextBlock Text="Hijo" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,12,0"/>
                        <TextBlock Text="→" FontSize="14" FontWeight="Bold" Foreground="#E67E00" Margin="0,0,4,0"/>
                        <TextBlock Text="Modifica a" FontSize="11" Foreground="{StaticResource BrushTextInactive}"/>
                    </StackPanel>
                    <Button Content="Cerrar" Padding="16,8" Cursor="Hand" Click="BtnCerrar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
