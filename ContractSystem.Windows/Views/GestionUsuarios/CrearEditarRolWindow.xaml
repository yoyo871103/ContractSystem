<Window x:Class="ContractSystem.Windows.Views.GestionUsuarios.CrearEditarRolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rol"
        Height="580" Width="520"
        MinHeight="500" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TxtTitulo" Text="Nuevo rol" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextActive}"/>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,16">
                <StackPanel>
                    <TextBlock Text="Nombre del rol" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNombre" FontSize="14" Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock Text="Descripci&#243;n (opcional)" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtDescripcion" FontSize="13" Padding="10,8" Margin="0,0,0,16"
                             TextWrapping="Wrap" AcceptsReturn="False"/>

                    <TextBlock Text="Permisos" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,8"/>

                    <!-- Botones seleccionar/deseleccionar todos -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Seleccionar todos" Padding="8,4" Margin="0,0,8,0"
                                Background="Transparent" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                Cursor="Hand" FontSize="11" Click="BtnSeleccionarTodos_Click"/>
                        <Button Content="Deseleccionar todos" Padding="8,4"
                                Background="Transparent" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                Cursor="Hand" FontSize="11" Click="BtnDeseleccionarTodos_Click"/>
                    </StackPanel>

                    <ItemsControl x:Name="PermisosPanel">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushAccent}" Margin="0,10,0,4"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,2" FontSize="12">
                                    <CheckBox.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Descripcion}" Foreground="{StaticResource BrushTextInactive}" FontSize="11"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </CheckBox.Content>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Width="88" Height="32" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button x:Name="BtnAceptar" Content="Guardar" Width="100" Height="32"
                            Background="{StaticResource BrushAccent}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnAceptar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
