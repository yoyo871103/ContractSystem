<Window x:Class="ContractSystem.Windows.Views.GestionUsuarios.CrearUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo usuario"
        Height="620" Width="500"
        MinHeight="520" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Nuevo usuario" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextActive}"/>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,16">
                <StackPanel>
                    <TextBlock Text="Nombre de usuario (inicio de sesi&#243;n)" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNombreUsuario" FontSize="14" Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock Text="Nombre para mostrar" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNombreParaMostrar" FontSize="14" Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock Text="Correo electr&#243;nico (opcional)" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtEmail" FontSize="14" Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock Text="Contrase&#241;a inicial" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <Border Margin="0,0,0,8" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White">
                        <Grid Height="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0">
                                <PasswordBox x:Name="TxtPassword" FontSize="14" Padding="10,8,4,8"
                                             BorderThickness="0" Background="Transparent"/>
                                <TextBox x:Name="TxtPasswordVisible" FontSize="14" Padding="10,8,4,8"
                                         BorderThickness="0" Background="Transparent" Visibility="Collapsed"
                                         TextChanged="TxtPasswordVisible_TextChanged"/>
                            </Grid>
                            <Button x:Name="BtnVerPassword" Grid.Column="1" Width="36" Height="36"
                                    Padding="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Mostrar contrase&#241;a" Click="BtnVerPassword_Click">
                                <TextBlock x:Name="IconoOjo" Text="&#xE890;" FontFamily="Segoe Fluent Icons"
                                           FontSize="14" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Border>
                    <TextBlock Text="Repetir contrase&#241;a" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <Border Margin="0,0,0,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White">
                        <Grid Height="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0">
                                <PasswordBox x:Name="TxtPasswordRepetir" FontSize="14" Padding="10,8,4,8"
                                             BorderThickness="0" Background="Transparent"/>
                                <TextBox x:Name="TxtPasswordRepetirVisible" FontSize="14" Padding="10,8,4,8"
                                         BorderThickness="0" Background="Transparent" Visibility="Collapsed"
                                         TextChanged="TxtPasswordRepetirVisible_TextChanged"/>
                            </Grid>
                            <Button x:Name="BtnVerPasswordRepetir" Grid.Column="1" Width="36" Height="36"
                                    Padding="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Mostrar contrase&#241;a" Click="BtnVerPasswordRepetir_Click">
                                <TextBlock x:Name="IconoOjoRepetir" Text="&#xE890;" FontFamily="Segoe Fluent Icons"
                                           FontSize="14" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Border>

                    <CheckBox x:Name="ChkRequiereCambio" Content="El usuario debe cambiar la contrase&#241;a en el pr&#243;ximo inicio de sesi&#243;n"
                              FontSize="12" Margin="0,0,0,16" IsChecked="True"/>

                    <TextBlock Text="Roles" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="RolesPanel" Margin="0,0,0,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Nombre}" IsChecked="{Binding IsSelected}" Margin="0,2"
                                          FontSize="13"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Permisos directos (adicionales a los del rol)" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,6"/>
                    <TextBlock Text="Estos permisos se otorgan al usuario sin necesidad de pertenecer a un rol."
                               FontSize="10" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <ItemsControl x:Name="PermisosPanel" Margin="0,0,0,8">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushAccent}" Margin="0,8,0,2"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,1" FontSize="12">
                                    <CheckBox.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Nombre}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Descripcion}" Foreground="{StaticResource BrushTextInactive}" FontSize="10"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </CheckBox.Content>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancelar" Content="Cancelar" Width="88" Height="32" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button x:Name="BtnAceptar" Content="Crear usuario" Width="120" Height="32"
                            Background="{StaticResource BrushAccent}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnAceptar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
