<Window x:Class="ContractSystem.Windows.Views.GestionUsuarios.EditarUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar usuario"
        Height="480" Width="440"
        MinHeight="420" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Editar usuario" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextActive}"/>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,16">
                <StackPanel>
                    <TextBlock Text="Nombre de usuario (inicio de sesión)" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNombreUsuario" FontSize="14" Padding="10,8" Margin="0,0,0,12" IsReadOnly="True"
                             Background="{StaticResource BrushSidebar}" Foreground="{StaticResource BrushTextInactive}"/>

                    <TextBlock Text="Nombre para mostrar" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNombreParaMostrar" FontSize="14" Padding="10,8" Margin="0,0,0,12"/>

                    <TextBlock Text="Correo electrónico (opcional)" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtEmail" FontSize="14" Padding="10,8" Margin="0,0,0,12"/>

                    <CheckBox x:Name="ChkActivo" Content="Usuario activo" FontSize="12" Margin="0,0,0,16"/>

                    <TextBlock Text="Roles" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="RolesPanel" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Nombre}" IsChecked="{Binding IsSelected}" Margin="0,2"
                                          FontSize="13"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancelar" Content="Cancelar" Width="88" Height="32" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button x:Name="BtnAceptar" Content="Guardar" Width="100" Height="32"
                            Background="{StaticResource BrushAccent}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnAceptar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
