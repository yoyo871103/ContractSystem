<Window x:Class="ContractSystem.Windows.Views.Configuracion.ProductoServicioDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Producto/Servicio"
        Height="520" Width="460"
        MinHeight="460" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtTitulo" Grid.Column="0" Text="Nuevo producto/servicio"
                               FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource BrushTextActive}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnCancelar_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource BrushTextInactive}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Cuerpo -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,16">
                <StackPanel>
                    <TextBlock Text="Tipo *" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbTipo" FontSize="14" Padding="10,8" Margin="0,0,0,10" SelectedIndex="0">
                        <ComboBoxItem Content="Producto" Tag="0"/>
                        <ComboBoxItem Content="Servicio" Tag="1"/>
                    </ComboBox>

                    <TextBlock Text="Código (opcional)" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtCodigo" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="Nombre *" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNombre" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="Descripción" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtDescripcion" FontSize="14" Padding="10,8" Margin="0,0,0,10"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Unidad de medida recomendada" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbUnidadMedida" FontSize="14" Padding="10,8" Margin="0,0,0,10"
                              DisplayMemberPath="NombreCorto"/>

                    <TextBlock Text="Precio estimado (opcional)" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPrecioEstimado" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Padding="16,8" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button Content="Guardar" Padding="16,8"
                            Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="BtnGuardar_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
