<Window x:Class="ContractSystem.Windows.Views.Configuracion.PlantillaDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plantilla de documento"
        Height="420" Width="460"
        MinHeight="380" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Nueva plantilla de documento"
                               FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource BrushTextActive}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnCancelar_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource BrushTextInactive}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Cuerpo -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,16">
                <StackPanel>
                    <TextBlock Text="Nombre de la plantilla *" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNombre" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="Tipo de documento *" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbTipo" FontSize="14" Padding="10,8" Margin="0,0,0,10" SelectedIndex="0">
                        <ComboBoxItem Content="Marco" Tag="0"/>
                        <ComboBoxItem Content="Específico" Tag="1"/>
                        <ComboBoxItem Content="Suplemento" Tag="2"/>
                    </ComboBox>

                    <TextBlock Text="Rol *" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbRol" FontSize="14" Padding="10,8" Margin="0,0,0,10" SelectedIndex="0">
                        <ComboBoxItem Content="Proveedor" Tag="0"/>
                        <ComboBoxItem Content="Cliente" Tag="1"/>
                    </ComboBox>

                    <TextBlock Text="Archivo (Word o PDF) *" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Seleccionar archivo" Padding="10,6"
                                Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="BtnSeleccionarArchivo_Click"/>
                        <TextBlock x:Name="TxtArchivoSeleccionado" Text="Ningún archivo seleccionado"
                                   FontSize="12" Foreground="{StaticResource BrushTextInactive}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <CheckBox x:Name="ChkRevisadoLegal" Content="Revisado por Legal" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Padding="16,8" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button Content="Guardar" Padding="16,8"
                            Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="BtnGuardar_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
