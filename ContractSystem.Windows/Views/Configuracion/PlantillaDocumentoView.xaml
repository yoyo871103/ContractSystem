<UserControl x:Class="ContractSystem.Windows.Views.Configuracion.PlantillaDocumentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de acciones -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Actualizar" Padding="12,6" Command="{Binding CargarCommand}"/>
            <Button Content="Nueva plantilla" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding NuevoCommand}"
                    Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"/>
            <Button Content="Editar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding EditarCommand}"
                    ToolTip="Editar la plantilla seleccionada"/>
            <Button Content="Descargar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding DescargarCommand}"
                    ToolTip="Descargar el archivo de la plantilla seleccionada"/>
            <Button Content="Eliminar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding EliminarCommand}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Plantillas}"
                  SelectedItem="{Binding Seleccionado, Mode=TwoWay}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                  MinHeight="200">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoDocumento}" Width="90"/>
                <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="80"/>
                <DataGridTextColumn Header="Archivo" Binding="{Binding NombreArchivo}" Width="150"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}" Width="90"/>
                <DataGridCheckBoxColumn Header="Legal" Binding="{Binding RevisadoPorLegal}" Width="50"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
