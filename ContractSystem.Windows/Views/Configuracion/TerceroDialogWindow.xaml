<Window x:Class="ContractSystem.Windows.Views.Configuracion.TerceroDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Tercero"
        Height="620" Width="540"
        MinHeight="500" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título (fijo) -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtTitulo" Grid.Column="0" Text="Nuevo tercero"
                               FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource BrushTextActive}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Cerrar" Click="BtnCancelar_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource BrushTextInactive}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Cuerpo (con scroll) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,16">
                <StackPanel>
                    <!-- Datos básicos -->
                    <TextBlock Text="Datos básicos" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,8"/>

                    <TextBlock Text="Código" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtCodigo" FontSize="14" Padding="10,8" Margin="0,0,0,10" MaxLength="64"/>

                    <TextBlock Text="Nombre *" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNombre" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="Razón social" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtRazonSocial" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="NIF/CIF" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNifCif" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="Tipo *" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbTipo" FontSize="14" Padding="10,8" Margin="0,0,0,10" SelectedIndex="0">
                        <ComboBoxItem Content="Cliente" Tag="0"/>
                        <ComboBoxItem Content="Proveedor" Tag="1"/>
                        <ComboBoxItem Content="Ambos" Tag="2"/>
                    </ComboBox>

                    <TextBlock Text="Ubicación expediente" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtUbicacion" FontSize="14" Padding="10,8" Margin="0,0,0,10" MaxLength="128"
                             ToolTip="Ubicación física del expediente (uso del área legal)"/>

                    <!-- Datos de contacto -->
                    <TextBlock Text="Datos de contacto" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrushTextInactive}" Margin="0,12,0,8"/>

                    <TextBlock Text="Dirección" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtDireccion" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="Teléfono" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtTelefono" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="Email" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtEmail" FontSize="14" Padding="10,8" Margin="0,0,0,10"/>

                    <!-- Contactos asociados -->
                    <TextBlock Text="Contactos asociados" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrushTextInactive}" Margin="0,12,0,8"/>

                    <DataGrid x:Name="DgContactos"
                              AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                              MinHeight="100" MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="Cargo" Binding="{Binding Cargo}" Width="100"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="120"/>
                            <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Agregar contacto" Padding="10,4" FontSize="11"
                                Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="BtnAgregarContacto_Click"/>
                        <Button Content="Eliminar seleccionado" Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                Background="Transparent" Foreground="{StaticResource BrushTextActive}"
                                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                Cursor="Hand" Click="BtnEliminarContacto_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie fijo: botones -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Padding="16,8" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button Content="Guardar" Padding="16,8"
                            Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="BtnGuardar_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
