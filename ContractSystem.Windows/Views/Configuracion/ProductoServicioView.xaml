<UserControl x:Class="ContractSystem.Windows.Views.Configuracion.ProductoServicioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Barra de acciones -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Actualizar" Padding="12,6" Command="{Binding CargarCommand}"/>
            <Button Content="Nuevo" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding NuevoCommand}"
                    Background="{StaticResource BrushAccent}" Foreground="White" BorderThickness="0"/>
            <Button Content="Editar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding EditarCommand}"/>
            <Button Content="Eliminar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding EliminarCommand}"/>
            <Button Content="Reactivar" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding ReactivarCommand}"/>
        </StackPanel>

        <!-- Filtros y búsqueda -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Filtrar por tipo:" VerticalAlignment="Center" FontSize="12"
                       Foreground="{StaticResource BrushTextInactive}" Margin="0,0,8,0"/>
            <ComboBox x:Name="CmbFiltroTipo" Width="140" Padding="6,4" FontSize="12"
                      SelectionChanged="CmbFiltroTipo_SelectionChanged">
                <ComboBoxItem Content="Todos" IsSelected="True" Tag=""/>
                <ComboBoxItem Content="Productos" Tag="0"/>
                <ComboBoxItem Content="Servicios" Tag="1"/>
            </ComboBox>
            <CheckBox Content="Incluir eliminados" IsChecked="{Binding IncludeDeleted, Mode=TwoWay}"
                      VerticalAlignment="Center" Margin="16,0,0,0"/>

            <!-- Búsqueda -->
            <Border Width="200" Height="28" Margin="16,0,0,0"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White"
                    CornerRadius="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource BrushTextInactive}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" VerticalContentAlignment="Center" FontSize="12"
                             Padding="0,4,8,4"
                             Background="Transparent"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Productos}"
                  SelectedItem="{Binding Seleccionado, Mode=TwoWay}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                  MinHeight="200"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="80"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="80"/>
                <DataGridTextColumn Header="U.M." Binding="{Binding UnidadMedida.NombreCorto}" Width="60"/>
                <DataGridTextColumn Header="Precio Est." Binding="{Binding PrecioEstimado, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding IsDeleted, Converter={StaticResource BoolToEstadoUsuario}}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Paginación -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding InfoPaginacion}" FontSize="12"
                       Foreground="{StaticResource BrushTextInactive}" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" Padding="8,4"
                        Command="{Binding PaginaAnteriorCommand}"
                        ToolTip="Página anterior"/>
                <TextBlock VerticalAlignment="Center" Margin="8,0" FontSize="12">
                    <Run Text="{Binding PaginaActual, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalPaginas, Mode=OneWay}"/>
                </TextBlock>
                <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" Padding="8,4"
                        Command="{Binding PaginaSiguienteCommand}"
                        ToolTip="Página siguiente"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
