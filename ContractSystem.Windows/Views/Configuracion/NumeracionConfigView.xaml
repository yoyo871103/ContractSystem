<UserControl x:Class="ContractSystem.Windows.Views.Configuracion.NumeracionConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ContractSystem.Windows.ViewModels"
             d:DesignWidth="700" d:DesignHeight="500"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Configuración de Numeración Automática" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextInactive}"/>
            <TextBlock Text="Defina el formato para la numeración automática de contratos y suplementos."
                       FontSize="12" Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Body con scroll -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                <!-- Formato -->
                <TextBlock Text="Formato de numeración" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Formato, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8" Padding="6" FontFamily="Consolas" FontSize="14"/>

                <!-- Variables disponibles -->
                <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Variables disponibles:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{StaticResource BrushTextInactive}">
                            <Run Text="{}{YYYY}" FontWeight="SemiBold"/> - Año actual (ej: 2026)<LineBreak/>
                            <Run Text="{}{MM}" FontWeight="SemiBold"/> - Mes actual (ej: 03)<LineBreak/>
                            <Run Text="{}{TIPO}" FontWeight="SemiBold"/> - Tipo de documento (MARCO, ESPECIFICO, INDEP, SUPL)<LineBreak/>
                            <Run Text="{}{CODIGO_CLIENTE}" FontWeight="SemiBold"/> - Código del tercero (si aplica)<LineBreak/>
                            <Run Text="{}{CONTADOR}" FontWeight="SemiBold"/> - Número secuencial automático
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Dígitos del contador -->
                <TextBlock Text="Dígitos del contador (padding con ceros)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBox x:Name="TxtDigitos" Width="60" Padding="6" TextAlignment="Center"
                             Text="{Binding DigitosPadding, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="OnlyNumeros_PreviewTextInput"/>
                    <TextBlock Text="(ej: 4 → 0001, 0002, ...)" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Tipo de contador -->
                <TextBlock Text="Tipo de contador" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <StackPanel Margin="0,0,0,16">
                    <RadioButton x:Name="RbPorAnio" Content="Reiniciar contador cada año"
                                 IsChecked="{Binding ContadorPorAnio}" GroupName="TipoContador" Margin="0,0,0,6"/>
                    <RadioButton Content="Contador global (continuo)"
                                 GroupName="TipoContador"/>
                </StackPanel>

                <!-- Vista previa -->
                <TextBlock Text="Vista previa" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border Background="#E8F4FC" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <TextBlock Text="{Binding VistaPrevia}" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushAccent}"/>
                </Border>
                <TextBlock Text="Ejemplo con tipo MARCO, tercero CLI001, contador 1"
                           FontSize="11" Foreground="Gray" Margin="0,0,0,16"/>

                <!-- Mensaje de error -->
                <TextBlock Text="{Binding MensajeError}" Foreground="{StaticResource BrushError}"
                           Visibility="{Binding MensajeError, Converter={StaticResource BoolToVisibility}}"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Pie fijo con botón guardar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrushBorder}" Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Guardar configuración" Command="{Binding GuardarCommand}"
                        Padding="16,8" Background="{StaticResource BrushAccent}" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
