<Window x:Class="ContractSystem.Windows.Views.Licensing.ActivacionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activación de Licencia - Sistema de Contratos"
        Height="480" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BrushBackground}">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icono y título -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"
                       FontSize="40" Foreground="{StaticResource BrushAccent}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Activación de Licencia" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource BrushTextActive}" HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Mensaje de estado -->
        <Border Grid.Row="1" x:Name="PnlMensaje" Padding="12,8" CornerRadius="4"
                Margin="0,0,0,16" Visibility="Collapsed">
            <TextBlock x:Name="TxtMensaje" TextWrapping="Wrap" FontSize="12"/>
        </Border>

        <!-- Código de instalación -->
        <TextBlock Grid.Row="2" Text="Su código de instalación:" FontSize="12"
                   Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtFingerprint" Grid.Column="0" IsReadOnly="True"
                     FontSize="13" FontFamily="Consolas" Padding="10,8"
                     Background="#F8F9FA" BorderBrush="{StaticResource BrushBorder}"
                     BorderThickness="1"/>
            <Button Grid.Column="1" Content="📋 Copiar" Margin="8,0,0,0"
                    Padding="12,8" Background="{StaticResource BrushHover}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    Cursor="Hand" Click="BtnCopiar_Click"/>
        </Grid>

        <!-- Instrucción -->
        <TextBlock Grid.Row="4" TextWrapping="Wrap" FontSize="11"
                   Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,16">
            <Run Text="Envíe este código al proveedor para obtener su clave de licencia."/>
            <LineBreak/>
            <Run x:Name="TxtContacto" Text=""/>
        </TextBlock>

        <!-- Clave de licencia -->
        <TextBlock Grid.Row="5" Text="Clave de licencia:" FontSize="12"
                   Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="6" x:Name="TxtClave" FontSize="13" FontFamily="Consolas"
                 Padding="10,8" AcceptsReturn="False" TextWrapping="Wrap"
                 VerticalAlignment="Top" Height="80"
                 BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"/>

        <!-- Botones -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="BtnActivar" Content="Activar" Padding="24,10"
                    Background="{StaticResource BrushAccent}" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="BtnActivar_Click"/>
            <Button x:Name="BtnSalir" Content="Salir" Padding="24,10"
                    Margin="10,0,0,0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    FontSize="13" Cursor="Hand" Click="BtnSalir_Click"/>
        </StackPanel>
    </Grid>
</Window>
