<Window x:Class="InventorySystem.Windows.Views.GestionUsuarios.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resetear contraseña"
        Height="320" Width="400"
        MinHeight="280" MinWidth="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Título (fijo) -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TxtTitulo" Text="Nueva contraseña temporal"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextInactive}"/>
            </Border>
            <!-- Cuerpo (con scroll) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,16">
                <StackPanel>
                <TextBlock x:Name="TxtUsuarioLabel" Text="Usuario:" FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtUsuario" FontSize="14" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,16"/>

                <TextBlock Text="Contraseña temporal (el usuario deberá cambiarla en el próximo inicio de sesión)"
                           FontSize="11" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White">
                        <Grid Height="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0">
                                <PasswordBox x:Name="TxtPassword" FontSize="14" Padding="10,8,4,8"
                                             BorderThickness="0" Background="Transparent"/>
                                <TextBox x:Name="TxtPasswordVisible" FontSize="14" Padding="10,8,4,8"
                                         BorderThickness="0" Background="Transparent" Visibility="Collapsed"
                                         TextChanged="TxtPasswordVisible_TextChanged"/>
                            </Grid>
                            <Button x:Name="BtnVerPassword" Grid.Column="1" Width="36" Height="36"
                                    Padding="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Mostrar contraseña" Click="BtnVerPassword_Click">
                                <TextBlock x:Name="IconoOjo" Text="&#xE890;" FontFamily="Segoe Fluent Icons"
                                           FontSize="14" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Border>
                    <Button x:Name="BtnGenerar" Grid.Column="1" Content="Generar" Margin="8,0,0,0"
                            Padding="12,8" Height="36" Click="BtnGenerar_Click"/>
                </Grid>
                </StackPanel>
            </ScrollViewer>
            <!-- Pie fijo -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancelar" Content="Cancelar" Width="88" Height="32" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnCancelar_Click"/>
                    <Button x:Name="BtnAceptar" Content="Establecer contraseña" Width="140" Height="32"
                            Background="{StaticResource BrushAccent}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnAceptar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
