<Window x:Class="InventorySystem.Windows.MainWindow"
        x:Name="MainWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventorySystem.Windows"
        mc:Ignorable="d"
        Title="Sistema de Inventario" Height="600" Width="1000"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        AllowsTransparency="False"
        Closing="MainWindow_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de título personalizada densa (arrastrar, minimizar, maximizar, pantalla completa, cerrar) -->
        <Border Grid.Row="0" Background="White" 
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Icono de la app (izquierda) -->
                <Border Grid.Column="0" Width="40" Height="28" 
                        Background="{StaticResource BrushAccent}"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" 
                               FontSize="14" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- Área central (arrastrable, doble clic = maximizar/restaurar) -->
                <Border Grid.Column="1" Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <!-- Usuario + controles de ventana (derecha) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Icono / foto de usuario (abre menú) -->
                    <Button x:Name="BtnUser" Background="Transparent" BorderThickness="0" Cursor="Hand" 
                            Width="32" Height="28" Padding="0" Margin="0"
                            ToolTip="Cuenta de usuario" Click="BtnUser_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="userBorder" Background="Transparent" Padding="2">
                                    <Border Width="20" Height="20" CornerRadius="10" 
                                            Background="{StaticResource BrushAccent}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid>
                                            <!-- Icono por defecto cuando no hay foto -->
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" 
                                                       FontSize="10" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <!-- Foto de perfil si existe -->
                                            <Image Width="20" Height="20" Stretch="UniformToFill"
                                                   Source="{Binding UserPhotoBytes, Converter={StaticResource ByteArrayToImageSource}}">
                                                <Image.Clip>
                                                    <EllipseGeometry RadiusX="10" RadiusY="10" Center="10,10"/>
                                                </Image.Clip>
                                            </Image>
                                        </Grid>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="userBorder" Property="Background" Value="{StaticResource BrushHover}"/>
                                    </Trigger>
                                    <!-- Ocultar icono cuando hay foto (DataContext binding no funciona en template, se usa en popup) -->
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Menú desplegable de usuario -->
                    <Popup x:Name="UserMenuPopup" PlacementTarget="{Binding ElementName=BtnUser}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border DataContext="{Binding DataContext, ElementName=MainWin}"
                                Background="White" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="0" MinWidth="280" Margin="0,4,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- Cabecera: foto, nombre, email -->
                                <StackPanel Orientation="Horizontal" Margin="16,16,16,12">
                                    <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource BrushBorder}" Margin="0,0,12,0">
                                        <Grid>
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                                       Foreground="{StaticResource BrushTextInactive}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Image Source="{Binding UserPhotoBytes, Converter={StaticResource ByteArrayToImageSource}}"
                                                   Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Clip>
                                                    <EllipseGeometry RadiusX="24" RadiusY="24" Center="24,24"/>
                                                </Image.Clip>
                                            </Image>
                                        </Grid>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UserDisplayName}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushTextActive}"/>
                                        <TextBlock Text="{Binding UserEmail}" FontSize="12" Foreground="{StaticResource BrushTextInactive}"
                                                   Visibility="{Binding HasUserEmail, Converter={StaticResource BoolToVisibility}}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Editar perfil (solo si no es admin SQL) -->
                                <Button Padding="16,10,16,10" Background="Transparent" Cursor="Hand"
                                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                                        Visibility="{Binding CanEditProfile, Converter={StaticResource BoolToVisibility}}"
                                        Click="UserMenu_OnOptionClick" Command="{Binding EditProfileCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{StaticResource BrushTextInactive}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Editar perfil" FontSize="13" Foreground="{StaticResource BrushTextActive}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{StaticResource BrushHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Cerrar sesión (siempre visible) -->
                                <Button BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,0"
                                        Padding="16,10,16,10" Background="Transparent" Cursor="Hand"
                                        Click="UserMenu_OnOptionClick" Command="{Binding LogoutCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <TextBlock Foreground="{StaticResource BrushAccent}" Text="Cerrar sesión" FontSize="13"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{StaticResource BrushHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <!-- Minimizar -->
                    <Button x:Name="BtnMinimize" Style="{StaticResource TitleBarButtonStyle}"
                            Click="BtnMinimize_Click" ToolTip="Minimizar">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="9" Foreground="{StaticResource BrushTextInactive}"/>
                    </Button>
                    <!-- Maximizar/Restaurar (respeta barra de tareas de Windows) -->
                    <Button x:Name="BtnMaximize" Style="{StaticResource TitleBarButtonStyle}"
                            Click="BtnMaximize_Click" ToolTip="Maximizar">
                        <TextBlock x:Name="TxtMaximizeIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="9" Foreground="{StaticResource BrushTextInactive}"/>
                    </Button>
                    <!-- Pantalla completa (oculta barra de tareas) -->
                    <Button x:Name="BtnFullScreen" Style="{StaticResource TitleBarButtonStyle}"
                            Click="BtnFullScreen_Click" ToolTip="Pantalla completa">
                        <TextBlock x:Name="TxtFullScreenIcon" Text="&#xE740;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="9" Foreground="{StaticResource BrushTextInactive}"/>
                    </Button>
                    <!-- Cerrar -->
                    <Button x:Name="BtnClose" Style="{StaticResource TitleBarCloseButtonStyle}"
                            PreviewMouseLeftButtonDown="BtnClose_PreviewMouseLeftButtonDown"
                            Click="BtnClose_Click" ToolTip="Cerrar">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="9" Foreground="{StaticResource BrushTextInactive}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenido principal: menú + área de contenido -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- Panel lateral de navegación -->
        <Border Grid.Column="0" Background="{StaticResource BrushSidebar}" 
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,16,0,8"
                                Visibility="{Binding IsSqlAdminOnly, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <!-- 1. Inicio -->
                        <Button Style="{StaticResource NavItemButtonStyle}" ToolTip="Inicio"
                                Command="{Binding NavigateToInicioCommand}">
                            <StackPanel>
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="20" Foreground="{StaticResource BrushAccent}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Inicio" FontSize="10" Foreground="{StaticResource BrushTextActive}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- 2. Inventario -->
                        <Button Style="{StaticResource NavItemButtonStyle}" ToolTip="Inventario"
                                Command="{Binding NavigateToInventarioCommand}">
                            <StackPanel>
                                <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="20" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Inventario" FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- 3. Productos -->
                        <Button Style="{StaticResource NavItemButtonStyle}" ToolTip="Productos"
                                Command="{Binding NavigateToProductosCommand}">
                            <StackPanel>
                                <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="20" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Productos" FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- 4. Almacenes -->
                        <Button Style="{StaticResource NavItemButtonStyle}" ToolTip="Almacenes"
                                Command="{Binding NavigateToAlmacenesCommand}">
                            <StackPanel>
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="20" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Almacenes" FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- 5. Ventas -->
                        <Button Style="{StaticResource NavItemButtonStyle}" ToolTip="Ventas"
                                Command="{Binding NavigateToVentasCommand}">
                            <StackPanel>
                                <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="20" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Ventas" FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- 6. Importar/Exportar -->
                        <Button Style="{StaticResource NavItemButtonStyle}" ToolTip="Importar / Exportar"
                                Command="{Binding NavigateToImportarExportarCommand}">
                            <StackPanel>
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="20" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Importar / Exportar" FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- 7. Informes -->
                        <Button Style="{StaticResource NavItemButtonStyle}" ToolTip="Informes"
                                Command="{Binding NavigateToInformesCommand}">
                            <StackPanel>
                                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="20" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Informes" FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
                <!-- 8. Configuración fijada abajo (visible para admin SQL y admin app) -->
                <Border Grid.Row="1" Padding="0,8,0,16"
                        Visibility="{Binding CanAccessConfiguracion, Converter={StaticResource BoolToVisibility}}"
                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Background="{StaticResource BrushSidebar}">
                    <Button Style="{StaticResource NavItemButtonStyle}" ToolTip="Configuración"
                            Command="{Binding NavigateToConfiguracionCommand}">
                        <StackPanel>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="20" Foreground="{StaticResource BrushTextInactive}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Config." FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- Área de trabajo: contenedor dinámico para vistas (Ventas, Compras, Inventario, etc.) -->
        <Border Grid.Column="1" Margin="24" Background="White" Padding="24"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Barra "Extraer": visible cuando hay una vista de módulo (no Inicio) -->
                <Button x:Name="BtnExtraer" Grid.Row="0" Content="Extraer"
                        Visibility="{Binding IsExtractVisible, Converter={StaticResource BoolToVisibility}}"
                        HorizontalAlignment="Right" Margin="0,0,0,12" Padding="12,6"
                        Background="{StaticResource BrushAccent}" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ExtraerVistaCommand}"
                        ToolTip="Abrir esta vista en una ventana independiente"/>
                <ContentControl x:Name="ContentArea" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                               Content="{Binding CurrentViewModel}"/>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
