<Window x:Class="InventorySystem.Windows.Shared.Dialogs.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        SizeToContent="WidthAndHeight"
        MinWidth="320" MaxWidth="480"
        Background="{StaticResource BrushBackground}"
        AllowsTransparency="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Barra de título: arrastrable + botón Cerrar (opcional) -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Área arrastrable -->
                <Border Grid.Column="0" Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <!-- Botón Cerrar (visibilidad configurable desde Show(..., showCloseButton)) -->
                <Button x:Name="BtnCloseWindow" Grid.Column="1" Style="{StaticResource TitleBarCloseButtonStyle}"
                        Click="BtnCloseWindow_Click" ToolTip="Cerrar">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                               Foreground="{StaticResource BrushTextInactive}"/>
                </Button>
            </Grid>
        </Border>

        <!-- Contenido del mensaje: icono + texto, separador, botones de acción -->
        <Border Grid.Row="1" Margin="0" Padding="20" Background="White"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Icono + mensaje -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="IconText" Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="32"
                               Foreground="{StaticResource BrushAccent}" VerticalAlignment="Top"
                               Margin="0,0,16,0" Visibility="Collapsed"/>
                    <TextBlock x:Name="MessageText" Grid.Column="1" TextWrapping="Wrap"
                               Foreground="{StaticResource BrushTextInactive}" FontSize="14"
                               VerticalAlignment="Center"/>
                </Grid>
                <!-- Separador -->
                <Border Grid.Row="1" Height="1" Background="{StaticResource BrushBorder}" Margin="0,0,0,16"/>
                <!-- Botones de acción (Sí, No, Aceptar, Cancelar) -->
                <StackPanel x:Name="ButtonsPanel" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnOk" Content="Aceptar" Width="80" Height="32" Margin="0,0,8,0"
                            Background="{StaticResource BrushAccent}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnOk_Click" Visibility="Collapsed"/>
                    <Button x:Name="BtnCancel" Content="Cancelar" Width="80" Height="32" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnCancel_Click" Visibility="Collapsed"/>
                    <Button x:Name="BtnYes" Content="Sí" Width="80" Height="32" Margin="0,0,8,0"
                            Background="{StaticResource BrushAccent}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnYes_Click" Visibility="Collapsed"/>
                    <Button x:Name="BtnNo" Content="No" Width="80" Height="32"
                            Background="Transparent" Foreground="{StaticResource BrushTextInactive}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Cursor="Hand" Click="BtnNo_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
