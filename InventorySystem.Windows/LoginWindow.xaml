<Window x:Class="InventorySystem.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Iniciar sesión - Sistema de Inventario"
        Height="440" Width="400"
        MinHeight="420" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BrushBackground}"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra superior: engrane + texto de conexión -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="12,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Icono engrane (configuración de conexión) -->
                    <Button x:Name="BtnConfigConexion" Grid.Column="0"
                            Background="Transparent" BorderThickness="0"
                            Width="36" Height="36" Padding="0" Cursor="Hand"
                            ToolTip="Configurar conexión"
                            Click="BtnConfigConexion_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent"
                                        CornerRadius="4" Padding="4">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="18" Foreground="{StaticResource BrushTextInactive}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource BrushHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Texto de conexión actual -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="Conexión actual" FontSize="10" Foreground="{StaticResource BrushTextInactive}"/>
                        <TextBlock x:Name="TxtConexionActual" Text="(no configurada)"
                                   FontSize="12" Foreground="{StaticResource BrushTextInactive}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <!-- Cerrar (opcional, para consistencia) -->
                    <Button Grid.Column="2" Width="28" Height="28" Padding="0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="BtnCerrar_Click" ToolTip="Cerrar">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Foreground="{StaticResource BrushTextInactive}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Contenido: usuario, contraseña, botón -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="32,20" MinHeight="320" VerticalAlignment="Center">
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                               FontSize="40" Foreground="{StaticResource BrushAccent}"
                               HorizontalAlignment="Center" Opacity="0.9"/>
                    <TextBlock Text="Sistema de Inventario" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextInactive}"
                               HorizontalAlignment="Center" Margin="0,12,0,20"/>

                    <TextBlock Text="Usuario" FontSize="12" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtUsuario" FontSize="14" Padding="10,8"
                             BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                             Margin="0,0,0,16"
                             KeyDown="TxtUsuario_KeyDown"/>

                    <TextBlock Text="Contraseña" FontSize="12" Foreground="{StaticResource BrushTextInactive}" Margin="0,0,0,4"/>
                    <!-- Campo contraseña con ojo dentro del borde (estilo nativo Windows) -->
                    <Border Margin="0,0,0,20" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0">
                                <PasswordBox x:Name="TxtPassword" FontSize="14" Padding="10,8,4,8"
                                             BorderThickness="0" Background="Transparent"
                                             KeyDown="TxtPassword_KeyDown"/>
                                <TextBox x:Name="TxtPasswordVisible" FontSize="14" Padding="10,8,4,8"
                                         BorderThickness="0" Background="Transparent"
                                         Visibility="Collapsed"
                                         TextChanged="TxtPasswordVisible_TextChanged"
                                         KeyDown="TxtPasswordVisible_KeyDown"/>
                            </Grid>
                            <Button x:Name="BtnVerPassword" Grid.Column="1" Width="36" Height="36"
                                    Padding="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Mostrar contraseña" Click="BtnVerPassword_Click">
                                <TextBlock x:Name="IconoOjo" Text="&#xE890;" FontFamily="Segoe Fluent Icons"
                                           FontSize="14" Foreground="{StaticResource BrushTextInactive}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Button x:Name="BtnIniciarSesion" Content="Iniciar sesión"
                            FontSize="14" Padding="24,12" MinHeight="44"
                            Background="{StaticResource BrushAccent}" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnIniciarSesion_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
